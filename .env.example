NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate independent random values of at least 32 bytes for production.
# Never reuse the Supabase service-role key for application session signing.
OWNER_SESSION_SECRET=
SHOP_SESSION_SECRET=

# Owner seed account for first deployment setup.
POS_OWNER_EMAIL=owner.admin@simplepos.sa
POS_OWNER_PASSWORD=change-this-before-production
