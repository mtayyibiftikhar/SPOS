{
  "name": "simple-pos",
  "version": "0.1.0",
  "description": "Cloud-ready browser POS with native shell packages for shops.",
  "author": "Global FSMS",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:pos": "next dev -p 3000",
    "dev:owner": "node scripts/local-owner-proxy.cjs 3001 http://localhost:3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "desktop:dev": "electron apps/desktop/main.cjs",
    "desktop:build": "electron-builder --config apps/desktop/electron-builder.yml --win nsis",
    "native:icons": "node scripts/generate-native-icons.cjs",
    "mobile:add:android": "cd apps/mobile && npx cap add android",
    "mobile:sync": "cd apps/mobile && npx cap sync android",
    "mobile:open": "cd apps/mobile && npx cap open android",
    "mobile:build:android": "cd apps/mobile && npx cap build android"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^16.2.10",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.5.16",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.16"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "sharp@0.34.5": true
  }
}
